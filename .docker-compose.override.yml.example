# Development environment override configuration example
# Copy this file as .docker-compose.override.yml to customize configuration

services:
  backend:
    environment:
      - DEBUG=True
      - DATABASE_URL=sqlite:///app/data/pv_simulator.db
    volumes:
      # Mount source code for hot reload in development
      - ./backend:/app
      - ./backend/data:/app/data
      - ./backend/uploads:/app/uploads
    command: uvicorn main:app --host 0.0.0.0 --port 8000 --reload

  frontend:
    volumes:
      # Mount source code in development
      - ./frontend:/app
      - /app/node_modules
    command: npm run dev
